# auto, llama_server, llama_cpp, openai, none
AIEQ_AI_PROVIDER=auto
# 0 means auto mode will not silently fall back to llama-cpp-python CPU inference.
AIEQ_AI_ALLOW_CPU_FALLBACK=0

# Recommended compact local model:
# https://huggingface.co/Qwen/Qwen3-4B-GGUF
AIEQ_LLAMA_MODEL_PATH=models/Qwen3-4B-Q4_K_M.gguf
AIEQ_LLAMA_N_CTX=12288
AIEQ_LLAMA_N_THREADS=8
AIEQ_LLAMA_N_GPU_LAYERS=-1
AIEQ_LLAMA_N_BATCH=1024
AIEQ_LLAMA_MAX_TOKENS=2048
AIEQ_LLAMA_TEMPERATURE=0.35

# Audio latency: low is the default. A custom value can be enabled from the app settings.
# AIEQ_AUDIO_LATENCY accepts low, high, seconds (0.05) or milliseconds (50ms).
AIEQ_AUDIO_BLOCK_SIZE=0
AIEQ_AUDIO_LATENCY=low

# Optional external llama.cpp server runtime. In this config auto mode prefers
# it and refuses CPU fallback when CUDA0 is unavailable.
AIEQ_LLAMA_SERVER_PATH=runtime/llama.cpp/llama-server.exe
AIEQ_LLAMA_SERVER_HOST=127.0.0.1
AIEQ_LLAMA_SERVER_PORT=8080
AIEQ_LLAMA_SERVER_AUTO_START=1
AIEQ_LLAMA_SERVER_STARTUP_TIMEOUT=45
AIEQ_LLAMA_SERVER_DEVICE=CUDA0
AIEQ_LLAMA_SERVER_REQUIRE_GPU=1
AIEQ_LLAMA_SERVER_PARALLEL=1
AIEQ_LLAMA_SERVER_FLASH_ATTN=on
AIEQ_LLAMA_SERVER_REASONING=auto
AIEQ_LLAMA_SERVER_REASONING_FORMAT=deepseek
AIEQ_LLAMA_SERVER_REASONING_BUDGET=1024
AIEQ_LLAMA_SERVER_CACHE_RAM=0
AIEQ_LLAMA_SERVER_LOG_PATH=
AIEQ_LLAMA_SERVER_EXTRA_ARGS=

# AutoEQ backend: auto, official, local.
# "official" requires the upstream autoeq Python package, currently Python >=3.8,<3.12.
AIEQ_AUTOEQ_BACKEND=auto
AIEQ_AUTOEQ_CONFIG=8_PEAKING_WITH_SHELVES

# Optional external training command for the AIEQ Lab window.
# Placeholders available: {dataset}, {model}, {output}.
# Example:
# AIEQ_TRAIN_COMMAND=python scripts/train_lora.py --dataset "{dataset}" --model "{model}" --output "{output}"
AIEQ_TRAIN_COMMAND=

# Optional paid provider.
OPENAI_API_KEY=
AIEQ_OPENAI_MODEL=gpt-5.2
