# auto, llama_cpp, openai, none
AIEQ_AI_PROVIDER=llama_cpp

# Recommended CPU-friendly local model:
# https://huggingface.co/Qwen/Qwen2.5-3B-Instruct-GGUF
AIEQ_LLAMA_MODEL_PATH=models/qwen2.5-3b-instruct-q4_k_m.gguf
AIEQ_LLAMA_N_CTX=4096
AIEQ_LLAMA_N_THREADS=7
AIEQ_LLAMA_N_GPU_LAYERS=0
AIEQ_LLAMA_MAX_TOKENS=900
AIEQ_LLAMA_TEMPERATURE=0.2

# AutoEQ backend: auto, official, local.
# "official" requires the upstream autoeq Python package, currently Python >=3.8,<3.12.
AIEQ_AUTOEQ_BACKEND=auto
AIEQ_AUTOEQ_CONFIG=8_PEAKING_WITH_SHELVES

# Optional paid provider.
OPENAI_API_KEY=
AIEQ_OPENAI_MODEL=gpt-5.2
